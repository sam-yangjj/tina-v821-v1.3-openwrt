 create mode 100644 linux/riscv32/get_error.c
 create mode 100644 linux/riscv32/get_scno.c
 create mode 100644 linux/riscv32/get_syscall_args.c
 create mode 100644 linux/riscv32/ioctls_arch0.h
 create mode 100644 linux/riscv32/ioctls_inc0.h
 create mode 100644 linux/riscv32/raw_syscall.h
 create mode 100644 linux/riscv32/set_error.c
 create mode 100644 linux/riscv32/set_scno.c
