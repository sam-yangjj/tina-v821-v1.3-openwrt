 linux/riscv32/arch_regs.c        | 11 +++++++++++
 linux/riscv32/get_error.c        | 19 +++++++++++++++++++
 linux/riscv32/get_scno.c         | 14 ++++++++++++++
 linux/riscv32/get_syscall_args.c | 19 +++++++++++++++++++
 linux/riscv32/ioctls_arch0.h     |  1 +
 linux/riscv32/ioctls_inc0.h      |  1 +
 linux/riscv32/raw_syscall.h      | 29 +++++++++++++++++++++++++++++
 linux/riscv32/set_error.c        | 20 ++++++++++++++++++++
 linux/riscv32/set_scno.c         | 15 +++++++++++++++
 linux/riscv32/syscallent.h       | 11 +++++++++++
 riscv.c                          |  4 ++--
 12 files changed, 146 insertions(+), 2 deletions(-)
