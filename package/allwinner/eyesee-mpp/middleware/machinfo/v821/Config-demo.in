config PACKAGE_eyesee-mpp-middleware-demo_config
	bool "eyesee-mpp-middleware-demo config"
	default n
	select PACKAGE_eyesee-mpp-middleware-demo
	help
	  move config out of PACKAGE_eyesee-mpp-middleware-demo to solve recursive dependency.

if PACKAGE_eyesee-mpp-middleware-demo_config

