+            V4L2_PIX_FMT_NV12,
+            V4L2_PIX_FMT_NV21,
+#endif
             V4L2_PIX_FMT_BGR24,
             V4L2_PIX_FMT_RGB24,
             V4L2_PIX_FMT_YVU420,
@@ -606,8 +627,10 @@ bool CvCaptureCAM_V4L::autosetup_capture_mode_v4l2()
             V4L2_PIX_FMT_YUV411P,
             V4L2_PIX_FMT_YUYV,
             V4L2_PIX_FMT_UYVY,
+#ifndef HAVE_SUNXI_VIN_ISP
             V4L2_PIX_FMT_NV12,
             V4L2_PIX_FMT_NV21,
+#endif
             V4L2_PIX_FMT_SBGGR8,
             V4L2_PIX_FMT_SGBRG8,
             V4L2_PIX_FMT_SGRBG8,
@@ -656,7 +679,12 @@ bool CvCaptureCAM_V4L::setFps(int value)
     CV_LOG_DEBUG(NULL, "VIDEOIO(V4L2:" << deviceName << "): FPS="
             << streamparm.parm.capture.timeperframe.denominator << "/"
             << streamparm.parm.capture.timeperframe.numerator);
+#ifdef HAVE_SUNXI_VIN_ISP
+    /* sunxi vin bug: VIDIOC_G_PARM return error parameter*/
+    fps = value;
+#else
     fps = streamparm.parm.capture.timeperframe.denominator;  // TODO use numerator
+#endif
     return true;
 }
 
@@ -704,6 +732,16 @@ bool CvCaptureCAM_V4L::initCapture()
         return false;
     }
 
+#ifdef HAVE_SUNXI_VIN_ISP
+    /* try to set framerate */
+    setFps(fps);
+
+    if (!autosetup_capture_mode_v4l2()) {
+        fprintf(stderr, "VIDEOIO ERROR: V4L2: Pixel format of incoming image is unsupported by OpenCV\n");
+        return false;
+    }
+#endif
+
     /* Find Window info */
     form = v4l2_format();
     form.type = type;
@@ -714,6 +752,7 @@ bool CvCaptureCAM_V4L::initCapture()
         return false;
     }
 
+#ifndef HAVE_SUNXI_VIN_ISP
     if (!autosetup_capture_mode_v4l2())
     {
         if (errno != EBUSY)
@@ -725,13 +764,20 @@ bool CvCaptureCAM_V4L::initCapture()
 
     /* try to set framerate */
     setFps(fps);
-
+#endif
+    unsigned int min;
     /* Buggy driver paranoia. */
     if (V4L2_TYPE_IS_MULTIPLANAR(type)) {
-        // TODO: add size adjustment if needed
-    } else {
-        unsigned int min;
+        min = form.fmt.pix_mp.width * 2;
 
+        if (form.fmt.pix_mp.plane_fmt[0].bytesperline < min)
+            form.fmt.pix_mp.plane_fmt[0].bytesperline = min;
+
+        min = form.fmt.pix_mp.plane_fmt[0].bytesperline * form.fmt.pix_mp.height;
+
+        if (form.fmt.pix_mp.plane_fmt[0].sizeimage < min)
+            form.fmt.pix_mp.plane_fmt[0].sizeimage = min;
+    } else {
         min = form.fmt.pix.width * 2;
 
         if (form.fmt.pix.bytesperline < min)
@@ -2006,6 +2052,31 @@ void CvCaptureCAM_V4L::releaseBuffers()
     requestBuffers(0);
 };
 
+#ifdef HAVE_SUNXI_VIN_ISP
+bool CvCaptureCAM_V4L::RAWSensor()
+{
+    struct v4l2_control ctrl;
+    struct v4l2_queryctrl qc_ctrl;
+
+    memset(&ctrl, 0, sizeof(struct v4l2_control));
+    memset(&qc_ctrl, 0, sizeof(struct v4l2_queryctrl));
+    ctrl.id = V4L2_CID_SENSOR_TYPE;
+    qc_ctrl.id = V4L2_CID_SENSOR_TYPE;
+
+    if (-1 == ioctl (deviceHandle, VIDIOC_QUERYCTRL, &qc_ctrl)){
+        fprintf(stderr, "V4L2: %s QUERY V4L2_CID_SENSOR_TYPE failed\n", deviceName.c_str());
+        return false;
+    }
+
+    if (-1 == ioctl(deviceHandle, VIDIOC_G_CTRL, &ctrl)) {
+        fprintf(stderr, "V4L2: %s G_CTRL V4L2_CID_SENSOR_TYPE failed\n", deviceName.c_str());
+        return false;
+    }
+
+    return ctrl.value == V4L2_SENSOR_TYPE_RAW;
+}
+#endif /* HAVE_SUNXI_VIN_ISP */
+
 bool CvCaptureCAM_V4L::streaming(bool startStream)
 {
     if (startStream != v4l_streamStarted)
@@ -2016,6 +2087,27 @@ bool CvCaptureCAM_V4L::streaming(bool startStream)
             return !startStream;
         }
 
+#ifdef HAVE_SUNXI_VIN_ISP
+    RawSensor = RAWSensor();
+
+    if (startStream && RawSensor) {
+        int VideoIndex = -1;
+
+        sscanf(deviceName.c_str(), "/dev/video%d", &VideoIndex);
+
+        IspPort = CreateAWIspApi();
+        IspId = -1;
+        IspId = IspPort->ispGetIspId(VideoIndex);
+        if (IspId >= 0)
+            IspPort->ispStart(IspId);
+    } else if (RawSensor && IspId >= 0 && IspPort) {
+        IspPort->ispStop(IspId);
+        DestroyAWIspApi(IspPort);
+        IspPort = NULL;
+        IspId = -1;
+    }
+#endif
+
         bool result = tryIoctl(startStream ? VIDIOC_STREAMON : VIDIOC_STREAMOFF, &type);
         if (result)
         {
@@ -2232,7 +2324,7 @@ bool VideoCapture_V4L_waitAny(const std::vector<VideoCapture>& streams, CV_OUT s
     for (size_t i = 0; i < N; ++i)
     {
         IVideoCapture* iCap = internal::VideoCapturePrivateAccessor::getIVideoCapture(streams[i]);
-        CvCaptureCAM_V4L *ptr_CvCaptureCAM_V4L = dynamic_cast<CvCaptureCAM_V4L*>(iCap);
+        CvCaptureCAM_V4L *ptr_CvCaptureCAM_V4L = static_cast<CvCaptureCAM_V4L*>(iCap);
         CV_Assert(ptr_CvCaptureCAM_V4L);
         capPtr[i] = ptr_CvCaptureCAM_V4L;
     }
