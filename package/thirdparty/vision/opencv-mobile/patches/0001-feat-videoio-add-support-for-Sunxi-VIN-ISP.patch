From d842f7873f93514960ab678077e34b734329bdb1 Mon Sep 17 00:00:00 2001
From: zhangyuanjing <zhangyuanjing@allwinnertech.com>
Date: Thu, 20 Nov 2025 12:08:10 +0800
Subject: [PATCH] feat(videoio): add support for Sunxi VIN ISP

- Add VINISP backend detection and configuration in CMake
- Implement Sunxi VIN ISP support in V4L2 capture
- Add necessary headers and flags for Sunxi VIN ISP integration
- Handle raw sensor type detection and ISP control
---
 CMakeLists.txt                            |  12 +++
 modules/videoio/CMakeLists.txt            |   5 ++
 modules/videoio/cmake/detect_vinisp.cmake |  13 +++
 modules/videoio/cmake/init.cmake          |   1 +
 modules/videoio/src/cap_v4l.cpp           | 102 ++++++++++++++++++++--
 5 files changed, 128 insertions(+), 5 deletions(-)
 create mode 100644 modules/videoio/cmake/detect_vinisp.cmake

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 03a1804..5b820ca 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -366,6 +366,9 @@ OCV_OPTION(WITH_TIFF "Include TIFF support" ON
 OCV_OPTION(WITH_V4L "Include Video 4 Linux support" ON
   VISIBLE_IF UNIX AND NOT ANDROID AND NOT APPLE
   VERIFY HAVE_CAMV4L OR HAVE_CAMV4L2 OR HAVE_VIDEOIO)
+OCV_OPTION(WITH_VINISP "Include Sunxi VIN ISP Support" ON
+  VISIBLE_IF ENABLE_SUNXIVINISP
+  VERIFY HAVE_VINISP)
 OCV_OPTION(WITH_DSHOW "Build VideoIO with DirectShow support" ON
   VISIBLE_IF WIN32 AND NOT ARM AND NOT WINRT
   VERIFY HAVE_DSHOW)
@@ -553,6 +556,8 @@ OCV_OPTION(ENABLE_CUDA_FIRST_CLASS_LANGUAGE "Enable CUDA as a first class langua
 OCV_OPTION(ENABLE_PYLINT              "Add target with Pylint checks"                            (BUILD_DOCS OR BUILD_EXAMPLES) IF (NOT CMAKE_CROSSCOMPILING AND NOT APPLE_FRAMEWORK) )
 OCV_OPTION(ENABLE_FLAKE8              "Add target with Python flake8 checker"                    (BUILD_DOCS OR BUILD_EXAMPLES) IF (NOT CMAKE_CROSSCOMPILING AND NOT APPLE_FRAMEWORK) )
 
+OCV_OPTION(ENABLE_SUNXIVINISP         "Enable Sunxi VIN ISP Server" OFF)
+
 if(ENABLE_IMPL_COLLECTION)
   add_definitions(-DCV_COLLECT_IMPL_DATA)
 endif()
@@ -1647,6 +1652,13 @@ if(WITH_V4L OR HAVE_V4L)
   status("    v4l/v4l2:" HAVE_V4L THEN "YES (${v4l_status})" ELSE NO)
 endif()
 
+if(WITH_VINISP OR HAVE_VINISP)
+  ocv_build_features_string(vinisp_status
+    IF HAVE_VINISP THEN "AWIspApi.h"
+    ELSE "NO")
+  status("    sunxi/vin:" HAVE_VINISP THEN "YES (${vinisp_status})" ELSE NO)
+endif()
+
 if(WITH_DSHOW OR HAVE_DSHOW)
   status("    DirectShow:" HAVE_DSHOW THEN YES ELSE NO)
 endif()
diff --git a/modules/videoio/CMakeLists.txt b/modules/videoio/CMakeLists.txt
index c8a03e7..3a71442 100644
--- a/modules/videoio/CMakeLists.txt
+++ b/modules/videoio/CMakeLists.txt
@@ -287,6 +287,11 @@ endif()
 
 ocv_target_link_libraries(${the_module} LINK_PRIVATE ${tgts})
 
+if(TARGET ocv.3rdparty.vinisp)
+  set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -DHAVE_SUNXI_VIN_ISP")
+  ocv_target_link_libraries(${the_module} LINK_PRIVATE m AWIspApi)
+endif()
+
 # copy FFmpeg dll to the output folder
 if(WIN32 AND HAVE_FFMPEG_WRAPPER)
   if(CMAKE_SIZEOF_VOID_P EQUAL 8)
diff --git a/modules/videoio/cmake/detect_vinisp.cmake b/modules/videoio/cmake/detect_vinisp.cmake
new file mode 100644
index 0000000..6bc8054
--- /dev/null
+++ b/modules/videoio/cmake/detect_vinisp.cmake
@@ -0,0 +1,13 @@
+# --- VINISP ---
+if(NOT HAVE_VINISP)
+  set(CMAKE_REQUIRED_QUIET TRUE) # for check_include_file
+  check_include_file(AWIspApi.h HAVE_VINISP)
+  if(HAVE_VINISP)
+    set(HAVE_VINISP TRUE)
+    set(defs)
+    list(APPEND defs "HAVE_VINISP")
+    ocv_add_external_target(vinisp "" "" "${defs}")
+  endif()
+endif()
+
+set(HAVE_VINISP ${HAVE_VINISP} PARENT_SCOPE)
diff --git a/modules/videoio/cmake/init.cmake b/modules/videoio/cmake/init.cmake
