+#include <AWIspApi.h>
+#endif
+
 #ifdef __OpenBSD__
 typedef uint32_t __u32;
 #endif
@@ -441,6 +446,14 @@ struct CvCaptureCAM_V4L CV_FINAL : public IVideoCapture
     void convertToRgb(const Buffer &currentBuffer);
 
     bool havePendingFrame;  // true if next .grab() should be noop, .retrieve() resets this flag
+
+#ifdef HAVE_SUNXI_VIN_ISP
