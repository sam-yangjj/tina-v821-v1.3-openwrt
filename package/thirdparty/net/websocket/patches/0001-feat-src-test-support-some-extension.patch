+#if RWS_SUPPORT_SEND_BIN
+void litews_frame_fill_with_send_bin_data(_rws_frame * f, unsigned char * header, const size_t data_size, rws_binary bin_type)
+{
+	const unsigned int size = (unsigned int)data_size;
+
+	if(bin_type == rws_binary_start)
+	{
+		*header++ = 0x00 | f->opcode;
+	}
+	else if(bin_type == rws_binary_continue)
+	{
+		*header++ = 0x00 | f->opcode;
+	}
+	else
+	{
+		*header++ = 0x80 | f->opcode;
+	}
+
+	if (size < 126)
+	{
+		*header++ = (size & 0xff) | (f->is_masked ? 0x80 : 0);
+		f->header_size = 2;
+	}
+	else if (size < 65536)
+	{
+		*header++ = 126 | (f->is_masked ? 0x80 : 0);
+		*header++ = (size >> 8) & 0xff;
+		*header++ = size & 0xff;
+		f->header_size = 4;
+	}
+	else
+	{
+		*header++ = 127 | (f->is_masked ? 0x80 : 0);
+
+		*(unsigned int *)header = 0;
+		header += 4;
+
+		*header++ = (size >> 24) & 0xff;
+		*header++ = (size >> 16) & 0xff;
+		*header++ = (size >> 8) & 0xff;
+		*header++ = size & 0xff;
+		f->header_size = 10;
+	}
+
+	if (f->is_masked)
+	{
+		memcpy(header, f->mask, 4);
+		f->header_size += 4;
+	}
+}
+#endif /* RWS_SUPPORT_SEND_BIN */
