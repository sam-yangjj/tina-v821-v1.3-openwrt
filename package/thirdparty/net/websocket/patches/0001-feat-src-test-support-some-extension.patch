+
+typedef struct {
+	SSL *ssl;
+	SSL_CTX *ctx;
+} ssl_session_t;
+
+void *port_ssl_open(rws_socket_t sock, char *host)
+{
+	ssl_session_t *session = (ssl_session_t *)malloc(sizeof(ssl_session_t));
+
+	if (session == NULL) {
+		perror("ssl session malloc failed");
+		return NULL;
+	}
+
+	RWS_LOGI("1. ssl init()\n");
+	SSL_library_init();
+	OpenSSL_add_all_algorithms();
+	SSL_load_error_strings();
+
+	RWS_LOGI("2. ssl ctx new()\n");
+	SSL_CTX *ctx = SSL_CTX_new(TLS_client_method());
+	if (ctx == NULL) {
+		perror("SSL_CTX_new failed");
+		return NULL;
+	}
+	session->ctx = ctx;
+
+	RWS_LOGI("3. ssl new()\n");
+	SSL *ssl = SSL_new(ctx);
+	if (ssl == NULL) {
+		perror("SSL_new failed");
+		return NULL;
+	}
+	session->ssl = ssl;
+
+	SSL_set_fd(ssl, sock);
+
+	/* set SNI externd */
+	const char *hostname = host;
+	if (SSL_set_tlsext_host_name(ssl, hostname) != 1) {
+		fprintf(stderr, "Error setting SNI\n");
+		return NULL;
+	}
+
+	RWS_LOGI("4. ssl connect() ...\n");
+	if (SSL_connect(ssl) != 1) {
+		perror("SSL_connect failed");
+		return NULL;
+	}
+	RWS_LOGI("5. ssl connect() successfully\n");
+
+	return (void *)session;
+}
+
+void port_ssl_close(void *_session)
+{
+	ssl_session_t *session = (ssl_session_t *)_session;
+
+	SSL *ssl = session->ssl;
+	SSL_CTX *ctx = session->ctx;
+
+	SSL_shutdown(ssl);
+
+	SSL_free(ssl);
+	SSL_CTX_free(ctx);
+
+	free(session);
+}
+
+int port_ssl_write(void *_session, const char *data, size_t data_size)
+{
+	int bytes_sent = 0;
+
+	ssl_session_t *session = (ssl_session_t *)_session;
+
+	SSL *ssl = session->ssl;
+
+	bytes_sent = SSL_write(ssl, data, data_size);
+
+	return bytes_sent;
+}
+
+int port_ssl_read(void *_session, char *buff, size_t read_bytes)
+{
+	int bytes_received = 0;
+
+	ssl_session_t *session = (ssl_session_t *)_session;
+
+	SSL *ssl = session->ssl;
+
+	bytes_received = SSL_read(ssl, buff, read_bytes);
+
+	return bytes_received;
+}
